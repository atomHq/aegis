# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://aegis:aegis@localhost:5432/aegis?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Encryption — generate with: make generate-key
MASTER_KEY=

# JWT — generate with: make generate-key
JWT_SECRET=

# SMTP (optional in development — codes logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aegis.dev

# Rate Limiting
DEFAULT_RATE_LIMIT=60

# Logging
LOG_LEVEL=info
